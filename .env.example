# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# Payload CMS
PAYLOAD_SECRET="generate-a-random-32-char-string"
DATABASE_URI="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"

# Cloudflare R2 (Media Storage)
R2_ENDPOINT="https://[ACCOUNT_ID].r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="your-bucket-name"

# Supabase: Used for the waitlist API route.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Cloudflare Analytics (Payload dashboard stats)
# Token: dash.cloudflare.com/profile/api-tokens → Create Token → Zone:Analytics:Read
# Zone ID: dash.cloudflare.com → select domain → Overview sidebar
# Requires Cloudflare proxy (orange cloud) enabled for the domain.
CF_ANALYTICS_TOKEN="your-cloudflare-api-token"
CF_ZONE_ID="your-zone-id"
